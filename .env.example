# Database
DATABASE_URL=postgresql+asyncpg://kps:kps@postgres:5432/knowledge_product_studio

# Cache
REDIS_URL=redis://redis:6379/0

# Search
OPENSEARCH_URL=http://opensearch:9200

# LLM provider abstraction — "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Confluence connector — OAuth 2.0 (3LO) Bearer access token via the API
# gateway. CONFLUENCE_BASE_URL is the gateway root including /wiki/rest/api,
# e.g. https://api.atlassian.com/ex/confluence/{cloudId}/wiki/rest/api
CONFLUENCE_BASE_URL=
CONFLUENCE_API_TOKEN=

# Auth (OAuth2 / OIDC, SSO-ready)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
JWT_SECRET=change-me

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Frontend (Next.js) — NEXT_PUBLIC_ vars are baked in at build time, not read
# at container runtime, so pass this as a docker build --build-arg too if you
# change it after building the web image.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
