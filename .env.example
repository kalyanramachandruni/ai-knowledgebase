# Database
DATABASE_URL=postgresql+asyncpg://kps:kps@postgres:5432/knowledge_product_studio

# Cache
REDIS_URL=redis://redis:6379/0

# Search
OPENSEARCH_URL=http://opensearch:9200

# LLM provider abstraction — "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Confluence connector
CONFLUENCE_BASE_URL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_USER_EMAIL=

# Auth (OAuth2 / OIDC, SSO-ready)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
JWT_SECRET=change-me

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
